generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  BLOCKED
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
}

enum VerificationTokenType {
  EMAIL_VERIFY
  EMPLOYEE_INVITE
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  OUT_OF_STOCK
}

enum InventoryMovementType {
  RECEIPT
  SALE
  RETURN
  ADJUSTMENT
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  ARCHIVED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentProviderType {
  PAYME
  CLICK
  MANUAL
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Plan {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  priceSum           Int
  maxProducts        Int?
  maxOrdersPerMonth  Int?
  maxEmployees       Int?
  features           Json
  createdAt          DateTime @default(now())

  tenants Tenant[]

  @@map("plans")
}

model Tenant {
  id           String       @id @default(uuid())
  name         String
  subdomain    String       @unique
  status       TenantStatus @default(TRIAL)
  planId       String
  plan         Plan         @relation(fields: [planId], references: [id])
  trialEndsAt  DateTime?
  telegramChatId String?
  logoUrl      String?
  themeColor   String?
  description  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users              User[]
  categories         Category[]
  products           Product[]
  productVariants    ProductVariant[]
  inventoryMovements InventoryMovement[]
  orders             Order[]
  invoices           BillingInvoice[]
  transactions       Transaction[]
  pageViews          PageView[]
  customers          Customer[]
  banners            Banner[]

  @@map("tenants")
}

model BillingInvoice {
  id                    String              @id @default(uuid())
  tenantId              String
  tenant                Tenant              @relation(fields: [tenantId], references: [id])
  planId                String
  planCode              String
  amount                Int
  status                InvoiceStatus       @default(PENDING)
  periodStart           DateTime
  periodEnd             DateTime
  dueDate               DateTime
  paidAt                DateTime?
  provider              PaymentProviderType?
  providerTransactionId String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("billing_invoices")
}

model Transaction {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  type            TransactionType
  category        String
  amount          Int
  description     String?
  orderId         String?
  order           Order?          @relation(fields: [orderId], references: [id])
  createdByUserId String?
  createdAt       DateTime        @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("transactions")
}

model PageView {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sessionId String
  path      String
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("page_views")
}

model User {
  id              String    @id @default(uuid())
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  email           String    @unique
  passwordHash    String
  role            UserRole
  name            String
  phone           String?
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  verificationTokens VerificationToken[]
  refreshTokens      RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

model VerificationToken {
  id        String                @id @default(uuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  createdAt DateTime              @default(now())

  @@index([userId])
  @@map("verification_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Category {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  slug      String
  createdAt DateTime @default(now())

  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  price       Int
  brand       String?
  color       String?
  code        String?
  currency    String        @default("UZS")
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  variants ProductVariant[]
  images   ProductImage[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("products")
}

model ProductVariant {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name              String?
  sku               String
  priceOverride     Int?
  stockQuantity     Int      @default(0)
  lowStockThreshold Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  position  Int
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model InventoryMovement {
  id            String                @id @default(uuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  variantId     String
  variant       ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  type          InventoryMovementType
  quantity      Int
  purchasePrice Int?
  note          String?
  orderId       String?
  order         Order?                @relation(fields: [orderId], references: [id])
  createdByUserId String?
  createdAt     DateTime              @default(now())

  @@index([tenantId])
  @@index([variantId])
  @@map("inventory_movements")
}

model Order {
  id               String      @id @default(uuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  customerId       String?
  customer         Customer?   @relation(fields: [customerId], references: [id])
  customerName     String
  customerPhone    String
  additionalPhones String[]    @default([])
  // Nullable at the DB level so historical orders (predating structured
  // addresses) don't block the migration - createOrderSchema requires all
  // three for every new order regardless.
  addressRegion    String?
  addressDistrict  String?
  addressMahalla   String?
  addressNote      String?
  status           OrderStatus @default(NEW)
  courierName      String?
  paymentMethod    String?
  totalAmount      Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  inventoryMovements InventoryMovement[]
  transactions      Transaction[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("orders")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  phone     String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([tenantId, phone])
  @@map("customers")
}

model Banner {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  imageUrl  String
  linkUrl   String?
  position  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("banners")
}

model OrderItem {
  id         String         @id @default(uuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  quantity   Int
  unitPrice  Int
  totalPrice Int

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id            String       @id @default(uuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus    OrderStatus?
  toStatus      OrderStatus
  changedByUserId String?
  createdAt     DateTime     @default(now())

  @@index([orderId])
  @@map("order_status_history")
}
